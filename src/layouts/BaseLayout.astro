---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hire Kerehama — Web Design in Tauranga',
  description = 'Professional websites for small businesses, clubs, and organizations. Based in Tauranga, NZ.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href="/" class="brand">kerehama.nz</a>
      <div class="nav-links">
        <a href="#work">Work</a>
        <a href="#pricing">Pricing</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Kerehama Andrews · <a href="https://kerehama.nz">kerehama.nz</a></p>
    </footer>
  </body>
</html>
